{
  "mcpServers": {
    "atlas-scratchpad": {
      "command": "node",
      "args": ["./packages/mcp-scratchpad/dist/bin.js"]
    },
    "atlas-synthesizer": {
      "command": "node",
      "args": ["./packages/mcp-synthesizer/dist/bin.js"]
    },
    "atlas-fidelity-auditor": {
      "command": "node",
      "args": ["./packages/mcp-fidelity-auditor/dist/bin.js"]
    },
    "atlas-traffic-sniffer": {
      "command": "node",
      "args": ["./packages/mcp-traffic-sniffer/dist/bin.js"]
    },
    "atlas-generators": {
      "command": "node",
      "args": ["./packages/generators/dist/bin.js"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-promote.sh"
          }
        ]
      }
    ]
  }
}
