{
  "name": "@atlas/mcp-fidelity-auditor",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Deterministic fidelity auditor MCP server for Atlas — byte-level diff with per-content-type normalization, fail-closed gating",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "atlas-mcp-fidelity-auditor": "./dist/bin.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/bin.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@atlas/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "microdiff": "^1.4.0",
    "parse5": "^7.1.2",
    "pdf-parse": "^2.4.5",
    "xml-c14n": "^0.0.6",
    "xml-crypto": "^6.1.2",
    "zod": "^3.23.8"
  }
}
