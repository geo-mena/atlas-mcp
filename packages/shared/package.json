{
    "name": "@atlas/shared",
    "version": "0.1.0-alpha.0",
    "private": true,
    "description": "Shared types, schemas, and constants for Atlas MCP servers",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js"
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts --clean",
        "dev": "tsup src/index.ts --format esm --watch --dts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "zod": "^3.23.8"
    }
}
