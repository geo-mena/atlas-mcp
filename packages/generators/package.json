{
  "name": "@atlas/generators",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Atlas artifact generators — OpenAPI spec, TypeScript MCP server scaffold, Vitest + nock test suite — driven by merged_facts from the scratchpad",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "atlas-mcp-generators": "./dist/bin.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/bin.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@atlas/mcp-scratchpad": "workspace:*",
    "@atlas/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  }
}
