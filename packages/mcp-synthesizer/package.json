{
  "name": "@atlas/mcp-synthesizer",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Deterministic conflict-resolution MCP server for Atlas — chained-plan synthesis of multi-source facts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "atlas-mcp-synthesizer": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@atlas/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  }
}
